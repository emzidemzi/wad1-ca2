<form class="ui stacked segment form" action="/dashboard/addlist" method="POST">
  <div class="field">
    <label>Title</label>
    <input placeholder="Title" type="text" name="title" autofocus required>
  </div>

  <div class="field">
    <label>Rating (1-5)</label>
    <input type="number" name="rating" min="1" max="5" required>
  </div>

  <button class="ui blue submit button">Add List</button>
</form>